# Fibonacci example for Deer language
# Calculate fib(20) iteratively

extern println(x)
extern printd(x)

# Define a low-precedence sequencing operator
def `:` binary:1 (x, y) y

# Iterative Fibonacci
def fibi(x int)
  var a = 0, b = 1, c in
  (for i = 2, i < x, 1 in
     c = a + b :
     a = b :
     b = c
  ) :
  b

def main()
  println(fibi(20))
